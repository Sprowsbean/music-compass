GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Supabase — get these from your Supabase project Settings > API
# Use the service_role key (not anon) so the backend can write to the table
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ── Run from inside the backend/ folder: `cd backend && uvicorn app.main:app --reload` ──
KAGGLE_CSV_PATH=data/kaggle/dataset.csv
